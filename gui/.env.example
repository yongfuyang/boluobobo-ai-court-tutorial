# === 菠萝王朝 Dashboard 环境变量 ===

# 认证 Token（必填，不设置会自动生成随机值，每次重启变化）
# BOLUO_AUTH_TOKEN=your-secret-token-here

# 朝堂频道 ID（可选，用于实时消息展示）
# Discord: 右键频道 → 复制频道 ID
# 不配置也能用：下旨功能会通过 gateway 通道发送
# VITE_COURT_CHANNEL=1234567890123456789

# 品牌名称（可选，显示在朝堂匾额上，默认 "AI"）
# VITE_BRAND_NAME=菠萝王朝

# GUI 监听端口（默认 18795）
# BOLUO_GUI_PORT=18795

# 天气城市（可选，JSON 格式）
# WEATHER_CITIES='[{"name":"北京","lat":39.90,"lon":116.40,"tz":"Asia/Shanghai"}]'
