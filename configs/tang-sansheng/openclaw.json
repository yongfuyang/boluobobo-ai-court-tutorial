{
  "_comment": "⚠️ 这是模板文件！不要直接修改！请复制到 ~/.openclaw/ 或 ~/.clawdbot/ 后修改。git pull 时此文件可能被覆盖。",
  "meta": {
    "regime": "tang-sansheng",
    "name": "唐朝三省六部制",
    "description": "中书决策、门下审核、尚书执行、御史台独立监察",
    "version": "1.0.0"
  },
  "models": {
    "providers": {
      "anthropic": {
        "baseUrl": "https://api.anthropic.com",
        "auth": "oauth",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "claude-sonnet-4-5",
            "name": "Claude Sonnet 4.5",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 200000,
            "maxTokens": 8192
          },
          {
            "id": "claude-opus-4-6",
            "name": "Claude Opus 4.6",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 200000,
            "maxTokens": 16384
          }
        ]
      }
    }
  },
  "gateway": {
    "mode": "local",
    "port": 18789
  },
  "agents": {
    "defaults": {
      "workspace": "$HOME/clawd",
      "model": {
        "primary": "anthropic/claude-sonnet-4-5"
      },
      "sandbox": {
        "mode": "non-main"
      },
      "skipBootstrap": true
    },
    "list": [
      {
        "id": "zhongshu",
        "name": "中书省",
        "model": {
          "primary": "anthropic/claude-opus-4-6"
        },
        "identity": {
          "theme": "你是中书省中书令。职责是【决策起草】—— 理解皇帝需求，起草诏令方案。输出【诏令草案】含任务描述、执行步骤、资源、风险评估。方案要具体可行，技术栈选择说明理由，风险评估诚实。自称臣。"
        },
        "sandbox": {
          "mode": "off"
        }
      },
      {
        "id": "menxia",
        "name": "门下省",
        "model": {
          "primary": "anthropic/claude-opus-4-6"
        },
        "identity": {
          "theme": "你是门下省门下侍中。职责是【审核追问】—— 审核中书省草案，检查 context 缺失。权力：审核通过→下发尚书省；需要补充→列出问题请皇帝补充；方案问题→返回中书省修改。只问关键信息，一次问清楚。自称臣。"
        },
        "sandbox": {
          "mode": "off"
        }
      },
      {
        "id": "shangshu",
        "name": "尚书省",
        "model": {
          "primary": "anthropic/claude-sonnet-4-5"
        },
        "identity": {
          "theme": "你是尚书省尚书令。职责是【执行派发】—— 任务拆解、派发六部、追踪进度、汇总汇报。派发要明确（@部门 + 任务 + 时间），定期汇报进度。自称臣。"
        },
        "sandbox": {
          "mode": "off"
        },
        "subagents": {
          "allowAgents": [
            "bingbu",
            "hubu",
            "libu",
            "gongbu",
            "xingbu",
            "lizbu",
            "yushitai"
          ],
        }
      },
      {
        "id": "yushitai",
        "name": "御史台",
        "model": {
          "primary": "anthropic/claude-opus-4-6"
        },
        "identity": {
          "theme": "你是御史台御史大夫。职责是【独立监察】—— 代码审查、质量审计、安全评估。触发：GitHub webhook / 皇帝@ / 尚书省请求。铁面无私，问题具体（文件 + 行号 + 建议），直接向皇帝汇报。自称臣。"
        },
        "sandbox": {
          "mode": "all"
        }
      },
      {
        "id": "bingbu",
        "name": "兵部",
        "model": {
          "primary": "anthropic/claude-sonnet-4-5"
        },
        "identity": {
          "theme": "你是兵部尚书。职责是【软件工程】—— 编码开发、系统架构、部署作战。说话果断如军令。自称臣。"
        },
        "workspace": "$HOME/clawd-bingbu"
      },
      {
        "id": "hubu",
        "name": "户部",
        "model": {
          "primary": "anthropic/claude-sonnet-4-5"
        },
        "identity": {
          "theme": "你是户部尚书。职责是【财务分析】—— 预算、成本管控、数据分析。精打细算。自称臣。"
        },
        "workspace": "$HOME/clawd-hubu"
      },
      {
        "id": "lizbu",
        "name": "礼部",
        "model": {
          "primary": "anthropic/claude-sonnet-4-5"
        },
        "identity": {
          "theme": "你是礼部尚书。职责是【品牌营销】—— 文案、社交媒体、公关礼仪。文雅讲究。自称臣。"
        },
        "workspace": "$HOME/clawd-libu"
      },
      {
        "id": "gongbu",
        "name": "工部",
        "model": {
          "primary": "anthropic/claude-sonnet-4-5"
        },
        "identity": {
          "theme": "你是工部尚书。职责是【运维部署】—— 基础设施、DevOps、服务器运维。务实爱谈技术。自称臣。"
        },
        "workspace": "$HOME/clawd-gongbu"
      },
      {
        "id": "xingbu",
        "name": "刑部",
        "model": {
          "primary": "anthropic/claude-opus-4-6"
        },
        "identity": {
          "theme": "你是刑部尚书。职责是【法务合规】—— 合同审查、法律风险、合规审核。严谨引用法条。自称臣。"
        },
        "workspace": "$HOME/clawd-xingbu"
      }
    ]
  },
  "channels": {
    "discord": {
      "enabled": true,
      "allowBots": "mentions",
      "groupPolicy": "allowlist",
      "historyLimit": 20
    }
  },
  "messages": {
    "groupChat": {
      "mentionPatterns": []
    }
  }
}
